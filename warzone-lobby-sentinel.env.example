# Warzone Lobby Sentinel — autonomous Xbox (zero manual input)
WZ_INSTALL_ROOT=/opt/warzone-lobby-sentinel
WZ_INGEST_HOST=0.0.0.0
WZ_INGEST_PORT=8098
WZ_POLL_INTERVAL_SEC=12

# AI learning persistence (baselines, session memory, user feedback)
WZ_LEARNING_FILE=/var/lib/warzone-sentinel/ai-learning.json

# array-firewall API (gaming-snapshot + packet shield via /api/v1/run)
# Co-hosted on router CT: http://127.0.0.1:8090
# Remote sentinel CT:     http://192.168.167.1:8090
WZ_ARRAY_FW_API_URL=http://192.168.167.1:8090
WZ_ARRAY_FW_API_TOKEN_FILE=/etc/warzone-sentinel/array-firewall.token
WZ_XBOX_IP=192.168.167.65

# Phone push (recommended — works while playing) + optional Xbox Live inbox
WZ_NTFY_ENABLED=1
WZ_NTFY_SERVER=https://ntfy.sh
# WZ_NTFY_TOPIC=warzone-sentinel-custom   # auto-generated if unset

# Xbox Live inbox (self-messages are muted — won't toast on console)
WZ_XBOX_NOTIFY_ENABLED=1
WZ_XBOX_NOTIFY_COOLDOWN_SEC=120
WZ_XBOX_NOTIFY_TOKEN_FILE=/etc/warzone-sentinel/xbox_notify.json
